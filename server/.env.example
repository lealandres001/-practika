# Puerto del servidor
PORT=4000

# Origen permitido para CORS (la web estática). Usa * para permitir todos.
CORS_ORIGIN=*

# Persistencia: "file" (JSON local, por defecto) o "postgres" (permanente)
STORAGE=file

# Solo si STORAGE=postgres.
# Local:    postgresql://usuario:clave@localhost:5432/practika
# Gestionado (Neon/Supabase/Render/RDS): usa la URL que te den (suele requerir SSL,
# el adaptador lo activa automáticamente cuando el host no es localhost).
DATABASE_URL=postgresql://usuario:clave@localhost:5432/practika
