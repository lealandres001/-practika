# PRACTIKA Backend — variables de entorno
# Copia este archivo a .env y ajusta los valores. NUNCA subas .env al repo.

# Servidor
PORT=4000
NODE_ENV=development

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=practika
DB_PASSWORD=practika
DB_NAME=practika

# JWT
JWT_ACCESS_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=cambia-esto-por-otro-secreto-distinto
JWT_REFRESH_TTL=7d
